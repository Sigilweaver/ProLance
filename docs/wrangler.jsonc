{
    "name": "prolance-docs",
    "compatibility_date": "2024-11-26",
    "assets": {
        "directory": "./build"
    },
    "routes": [
        {
            "pattern": "sigilweaver.app/prolance/docs",
            "zone_name": "sigilweaver.app"
        },
        {
            "pattern": "sigilweaver.app/prolance/docs/*",
            "zone_name": "sigilweaver.app"
        }
    ]
}
